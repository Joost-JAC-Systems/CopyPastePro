<Window x:Class="CopyPastePro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CopyPastePro.Controls"
        Title="CopyPaste Pro — Manager"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Height="720" Width="1080"
        MinHeight="500" MinWidth="920"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown"
        PreviewMouseWheel="Window_PreviewMouseWheel"
        Background="{DynamicResource BgDarkBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Grid x:Name="UiScaleRoot" Background="{DynamicResource BgDarkBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="72"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource BgDarkBrush}" BorderThickness="0">
            <StackPanel VerticalAlignment="Top" Margin="0,12,0,0">
                <Image Source="{DynamicResource AppIconTransparent}" Width="44" Height="44" Margin="0,0,0,12"
                       RenderOptions.BitmapScalingMode="HighQuality" ToolTip="CopyPaste Pro"/>
                <RadioButton x:Name="NavHistory" Content="📋" ToolTip="History" IsChecked="True" GroupName="Nav"
                             Style="{StaticResource NavRadio}" Click="NavHistory_Click"/>
                <RadioButton x:Name="NavImages" Content="🖼" ToolTip="Image library" GroupName="Nav"
                             Style="{StaticResource NavRadio}" Click="NavImages_Click"/>
                <RadioButton x:Name="NavSettings" Content="⚙" ToolTip="Settings" GroupName="Nav"
                             Style="{StaticResource NavRadio}" Click="NavSettings_Click"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Background="{DynamicResource BgDarkBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource BgDarkBrush}" Padding="20,14,20,8" BorderThickness="0">
                <Grid>
                    <StackPanel>
                        <TextBlock x:Name="PageTitle" Text="Clipboard history" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="StatsText" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock x:Name="StatusText" Text="● Active" Foreground="{DynamicResource SuccessBrush}" Margin="0,0,16,0"/>
                        <Button Content="Backup now" Style="{StaticResource GhostButton}" Click="BackupNow_Click" Margin="0,0,8,0"/>
                        <Button Content="Quick access" Style="{StaticResource GhostButton}" Click="OpenQuickAccess_Click" Margin="0,0,8,0"/>
                        <Button Content="Hide to tray" Style="{StaticResource GhostButton}" Click="Hide_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid x:Name="HistoryPanel" Grid.Row="1" Margin="12,0,12,12" Background="{DynamicResource BgDarkBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="400" MinWidth="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{DynamicResource BgPanelBrush}" CornerRadius="12" Padding="12" Margin="0,0,4,0" BorderThickness="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBox x:Name="SearchBox" Grid.Row="0" Margin="0,0,0,8" TextChanged="SearchBox_TextChanged"/>
                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="SortCombo" Grid.Column="0" SelectionChanged="FilterChanged"/>
                            <ComboBox x:Name="CategoryCombo" Grid.Column="2" SelectionChanged="FilterChanged"/>
                        </Grid>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                            <ComboBox x:Name="FilterCombo" Width="140" SelectionChanged="FilterChanged">
                                <ComboBoxItem Content="All types" IsSelected="True"/>
                                <ComboBoxItem Content="Text"/>
                                <ComboBoxItem Content="Images"/>
                                <ComboBoxItem Content="Files"/>
                                <ComboBoxItem Content="HTML"/>
                                <ComboBoxItem Content="Rich Text"/>
                                <ComboBoxItem Content="Other"/>
                            </ComboBox>
                            <CheckBox x:Name="FavoritesOnlyBox" Content="★ Favorites" Margin="12,0,0,0" VerticalAlignment="Center" Checked="FilterChanged" Unchecked="FilterChanged"/>
                            <CheckBox x:Name="GroupByCategoryBox" Content="Group" Margin="12,0,0,0" VerticalAlignment="Center" Checked="FilterChanged" Unchecked="FilterChanged"/>
                        </StackPanel>
                        <ListBox x:Name="HistoryList" Grid.Row="3"
                                 SelectionChanged="HistoryList_SelectionChanged"
                                 MouseDoubleClick="HistoryList_MouseDoubleClick"
                                 PreviewMouseRightButtonDown="HistoryList_PreviewMouseRightButtonDown"
                                 ContextMenuOpening="HistoryList_ContextMenuOpening">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,2">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Icon}" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Preview}" TextTrimming="CharacterEllipsis" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Meta}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10" Margin="18,2,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <UniformGrid Grid.Row="4" Columns="4" Margin="0,10,0,0">
                            <Button Content="Copy" ToolTip="Copy to system clipboard" Style="{StaticResource GhostButton}" Click="Copy_Click" Margin="0,0,4,0"/>
                            <Button Content="★" ToolTip="Favorite" Style="{StaticResource GhostButton}" Click="Favorite_Click" Margin="4,0"/>
                            <Button Content="Pin" Style="{StaticResource GhostButton}" Click="Pin_Click" Margin="4,0"/>
                            <Button Content="Del" Style="{StaticResource GhostButton}" Click="Delete_Click" Margin="4,0,0,0"/>
                        </UniformGrid>
                    </Grid>
                </Border>
                <Border Grid.Column="1" Background="{DynamicResource BgPanelBrush}" CornerRadius="12" Padding="16" Margin="4,0,0,0" BorderThickness="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="PreviewTitle" Text="Select an item to preview" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,12"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <Grid Grid.Row="1">
                            <ScrollViewer x:Name="PreviewContentScroll" VerticalScrollBarVisibility="Auto" Background="Transparent" BorderThickness="0">
                                <StackPanel Background="Transparent">
                                    <TextBox x:Name="PreviewText" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="240"
                                             Visibility="Collapsed" VerticalScrollBarVisibility="Auto"
                                             ContextMenuOpening="PreviewText_ContextMenuOpening"/>
                                    <ListBox x:Name="PreviewFiles" Visibility="Collapsed"/>
                                </StackPanel>
                            </ScrollViewer>
                            <controls:ZoomableImagePreview x:Name="PreviewImageZoom" Visibility="Collapsed"
                                                             ContextMenuOpening="PreviewImageZoom_ContextMenuOpening"/>
                        </Grid>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
                            <Button Content="Copy to clipboard" Style="{StaticResource GhostButton}" Click="Copy_Click" Margin="0,0,8,0"
                                    ToolTip="Put this clip on the clipboard without leaving the manager"/>
                            <Button Content="Paste to app" Style="{StaticResource PrimaryButton}" Click="PasteToApp_Click"
                                    ToolTip="Hide this window and paste into the app you were using (Enter or double-click)"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Grid x:Name="SettingsHost" Grid.Row="1" Margin="12,0,12,12" Visibility="Collapsed" Background="{DynamicResource BgDarkBrush}"/>
            <Grid x:Name="ImageLibraryHost" Grid.Row="1" Margin="12,0,12,12" Visibility="Collapsed" Background="{DynamicResource BgDarkBrush}"/>

            <Border Grid.Row="2" Background="{DynamicResource BgDarkBrush}" Padding="16,8,16,12" BorderThickness="0">
                <Grid>
                    <TextBlock x:Name="FooterText" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Export database…" Style="{StaticResource GhostButton}" Click="ExportDatabase_Click" Margin="0,0,8,0"/>
                        <Button Content="Empty database" Style="{StaticResource GhostButton}" Click="EmptyDatabase_Click" Margin="0,0,8,0"/>
                        <Button Content="Recategorize all" Style="{StaticResource GhostButton}" Click="Recategorize_Click" Margin="0,0,8,0"/>
                        <Button Content="Clear unpinned" Style="{StaticResource GhostButton}" Click="ClearUnpinned_Click" Margin="0,0,8,0"/>
                        <Button Content="Clear app history" Style="{StaticResource GhostButton}" Click="ClearAppHistory_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
