<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="BgDark">#0F1117</Color>
    <Color x:Key="BgPanel">#171B26</Color>
    <Color x:Key="BgCard">#1E2433</Color>
    <Color x:Key="BgCardHover">#252D40</Color>
    <Color x:Key="Accent">#6C5CE7</Color>
    <Color x:Key="AccentLight">#A29BFE</Color>
    <Color x:Key="TextPrimary">#F5F7FF</Color>
    <Color x:Key="TextMuted">#8B93A8</Color>
    <Color x:Key="Border">#2A3145</Color>
    <Color x:Key="Success">#00B894</Color>
    <Color x:Key="Danger">#FF6B6B</Color>

    <SolidColorBrush x:Key="BgDarkBrush" Color="{StaticResource BgDark}"/>
    <SolidColorBrush x:Key="BgPanelBrush" Color="{StaticResource BgPanel}"/>
    <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}"/>
    <SolidColorBrush x:Key="BgCardHoverBrush" Color="{StaticResource BgCardHover}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource AccentLight}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Border}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}"/>
</ResourceDictionary>
