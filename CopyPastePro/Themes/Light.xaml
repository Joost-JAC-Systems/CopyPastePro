<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="BgDark">#F0F2F8</Color>
    <Color x:Key="BgPanel">#FFFFFF</Color>
    <Color x:Key="BgCard">#E8ECF4</Color>
    <Color x:Key="BgCardHover">#DCE2EF</Color>
    <Color x:Key="Accent">#5B4FCF</Color>
    <Color x:Key="AccentLight">#7C6CF0</Color>
    <Color x:Key="TextPrimary">#1A1D26</Color>
    <Color x:Key="TextMuted">#5C6478</Color>
    <Color x:Key="Border">#C8D0E0</Color>
    <Color x:Key="Divider">#D8DEE8</Color>
    <Color x:Key="Success">#00A884</Color>
    <Color x:Key="Danger">#E74C3C</Color>
    <Color x:Key="StickyHeader">#5B4FCF</Color>
    <SolidColorBrush x:Key="BgDarkBrush" Color="{StaticResource BgDark}"/>
    <SolidColorBrush x:Key="BgPanelBrush" Color="{StaticResource BgPanel}"/>
    <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}"/>
    <SolidColorBrush x:Key="BgCardHoverBrush" Color="{StaticResource BgCardHover}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource AccentLight}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Border}"/>
    <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource Divider}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}"/>
    <SolidColorBrush x:Key="StickyHeaderBrush" Color="{StaticResource StickyHeader}"/>
</ResourceDictionary>
