<Window x:Class="CopyPastePro.Views.AppDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CopyPaste Pro"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        MinWidth="320"
        MaxWidth="440"
        KeyDown="Window_KeyDown">
    <Border Background="{DynamicResource BgPanelBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Margin="16"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.55" Color="#000000"/>
        </Border.Effect>
        <Grid Margin="20,18,20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="IconBadge" Width="40" Height="40" CornerRadius="10" Margin="0,0,12,0"
                        VerticalAlignment="Top" Background="Transparent">
                    <Grid>
                        <Image x:Name="IconImage" Width="36" Height="36"
                               Source="{DynamicResource AppIconTransparent}"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Visibility="Collapsed"/>
                        <TextBlock x:Name="IconGlyph" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                <TextBlock x:Name="TitleText" Grid.Column="1" TextWrapping="Wrap"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </Grid>

            <ScrollViewer Grid.Row="1" MaxHeight="280" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
                <TextBlock x:Name="MessageText" TextWrapping="Wrap" LineHeight="20"
                           Foreground="{DynamicResource TextMutedBrush}" FontSize="13"/>
            </ScrollViewer>

            <StackPanel x:Name="ButtonPanel" Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Right"/>
        </Grid>
    </Border>
</Window>
