<UserControl x:Class="CopyPastePro.Views.ImageLibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:CopyPastePro.Controls"
             Background="{DynamicResource BgDarkBrush}">
    <Grid Background="{DynamicResource BgDarkBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource BgPanelBrush}" CornerRadius="12" Padding="12" Margin="0,0,0,8" BorderThickness="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal">
                    <CheckBox x:Name="AutoSaveBox" Content="Auto-save new images" VerticalAlignment="Center" Margin="0,0,8,0"
                              Checked="AutoSave_Changed" Unchecked="AutoSave_Changed"/>
                    <Button x:Name="AutoSaveInfoBtn" Content="ⓘ" Style="{StaticResource GhostButton}" Padding="6,2" Margin="0,0,12,0"
                            FontSize="12" Click="AutoSaveInfo_Click" ToolTip="About auto-save"/>
                    <Button Content="Choose folder…" Style="{StaticResource GhostButton}" Click="ChooseAutoSaveFolder_Click" Margin="0,0,8,0"/>
                    <Button Content="Open folder" Style="{StaticResource GhostButton}" Click="OpenAutoSaveFolder_Click" Margin="0,0,8,0"/>
                    <TextBlock x:Name="AutoSaveFolderPathText" TextTrimming="CharacterEllipsis" MaxWidth="280" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                    <CheckBox x:Name="SyncFolderBox" Content="Sync to folder" VerticalAlignment="Center" Margin="0,0,8,0"
                              Checked="SyncFolder_Changed" Unchecked="SyncFolder_Changed"/>
                    <Button x:Name="SyncInfoBtn" Content="ⓘ" Style="{StaticResource GhostButton}" Padding="6,2" Margin="0,0,12,0"
                            FontSize="12" Click="SyncInfo_Click" ToolTip="About sync folder"/>
                    <Button Content="Choose folder…" Style="{StaticResource GhostButton}" Click="ChooseSyncFolder_Click" Margin="0,0,8,0"/>
                    <Button Content="Open folder" Style="{StaticResource GhostButton}" Click="OpenSyncFolder_Click" Margin="0,0,8,0"/>
                    <TextBlock x:Name="SyncFolderPathText" TextTrimming="CharacterEllipsis" MaxWidth="280" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
                </StackPanel>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                    <Button x:Name="ScreenshotBtn" Content="📷 Screenshot" Style="{StaticResource GhostButton}"
                            Click="Screenshot_Click" Margin="0,0,12,0"
                            ToolTip="Hide app and capture with Windows snip (Ctrl+Shift+S)"/>
                    <Button x:Name="FocusPreviewToggle" Content="⊞ Focus preview" Style="{StaticResource GhostButton}"
                            Click="FocusPreviewToggle_Click" Margin="0,0,12,0" ToolTip="Narrow image list + large preview panel"/>
                    <ComboBox x:Name="SortCombo" Width="150" SelectionChanged="Filter_Changed" Margin="0,0,8,0"/>
                    <CheckBox x:Name="FavoritesOnlyBox" Content="★ Favorites" Margin="0,0,12,0" VerticalAlignment="Center"
                              Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                    <CheckBox x:Name="AutoSavedOnlyBox" Content="Auto-saved only" Margin="0,0,12,0" VerticalAlignment="Center"
                              Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                    <Button Content="Refresh" Style="{StaticResource GhostButton}" Click="Refresh_Click" Margin="0,0,8,0"/>
                    <Button Content="Export all…" Style="{StaticResource GhostButton}" Click="ExportAll_Click"/>
                    <TextBlock x:Name="ImageCountText" Margin="16,0,0,0" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextMutedBrush}" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="ContentGrid" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftCol" Width="*" MinWidth="320"/>
                <ColumnDefinition x:Name="RightCol" Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- Grid thumbnail view (default) -->
            <Border x:Name="ImageGridHost" Grid.Column="0" Background="{DynamicResource BgPanelBrush}" CornerRadius="12" Padding="10" Margin="0,0,4,0" BorderThickness="0"
                    PreviewMouseRightButtonDown="Thumbs_PreviewMouseRightButtonDown"
                    ContextMenuOpening="Thumbs_ContextMenuOpening">
                <ScrollViewer VerticalScrollBarVisibility="Auto" PreviewMouseWheel="ListScroll_PreviewMouseWheel">
                    <ItemsControl x:Name="ImageGrid">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="{Binding ThumbSize}" Height="{Binding ThumbSize}" Margin="4" CornerRadius="10"
                                        Background="{DynamicResource BgCardBrush}" Cursor="Hand"
                                        BorderBrush="{DynamicResource AccentBrush}" BorderThickness="{Binding SelectionThickness}"
                                        MouseLeftButtonUp="Thumb_Click" Tag="{Binding}">
                                    <Grid>
                                        <Image Source="{Binding Thumbnail}" Stretch="Uniform" Margin="6"/>
                                        <TextBlock Text="{Binding Caption}" VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                                                   Background="#99000000" Foreground="White" FontSize="9" Padding="6,4"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Single-column list view (focus preview mode) -->
            <Border x:Name="ImageListHost" Grid.Column="0" Background="{DynamicResource BgPanelBrush}" CornerRadius="12" Padding="6" Margin="0,0,4,0"
                    BorderThickness="0" Visibility="Collapsed">
                <ListBox x:Name="ImageList" BorderThickness="0" Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         SelectionChanged="ImageList_SelectionChanged"
                         PreviewMouseRightButtonDown="Thumbs_PreviewMouseRightButtonDown"
                         ContextMenuOpening="Thumbs_ContextMenuOpening"
                         PreviewMouseWheel="ListScroll_PreviewMouseWheel">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,4"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Padding="4">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgCardHoverBrush}"/>
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgCardBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="2,2" Cursor="Hand" Tag="{Binding}" MouseLeftButtonUp="Thumb_Click">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="48" Height="48" CornerRadius="6" Background="{DynamicResource BgCardBrush}">
                                    <Image Source="{Binding ListThumbnail}" Stretch="Uniform" Margin="3"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,4,0">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding Subtitle}" FontSize="10" TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource TextMutedBrush}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Border x:Name="DetailPanel" Grid.Column="1" Background="{DynamicResource BgPanelBrush}" CornerRadius="12" Padding="14" Margin="4,0,0,0" BorderThickness="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="DetailTitle" Text="Select an image" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"
                               Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                    <Border Grid.Row="1" Background="{DynamicResource BgCardBrush}" CornerRadius="10" ClipToBounds="True">
                        <Grid x:Name="PreviewChromeHost"
                              MouseMove="PreviewChrome_MouseMove"
                              MouseLeave="PreviewChrome_MouseLeave"
                              ContextMenuOpening="DetailPreview_ContextMenuOpening">
                            <controls:ZoomableImagePreview x:Name="DetailPreview"
                                                             ContextMenuOpening="DetailPreview_ContextMenuOpening"/>
                            <Border x:Name="ActionOverlay" VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                                    Padding="8,0,8,10" Background="Transparent">
                                <WrapPanel HorizontalAlignment="Center">
                                    <Button Content="Save as…" Style="{StaticResource PreviewOverlayButton}" Click="SaveAs_Click" ToolTip="Save as file"/>
                                    <Button Content="Copy" Style="{StaticResource PreviewOverlayButton}" Click="Copy_Click" ToolTip="Copy to clipboard"/>
                                    <Button Content="Paste to app" Style="{StaticResource PreviewOverlayButton}" Click="PasteToApp_Click" ToolTip="Paste into previous app"/>
                                    <Button Content="Open file" Style="{StaticResource PreviewOverlayButton}" Click="OpenFile_Click" ToolTip="Open image file"/>
                                    <Button x:Name="FavoriteOverlayBtn" Content="★" Style="{StaticResource PreviewOverlayButton}" Click="Favorite_Click" ToolTip="Favorite" MinWidth="34" Padding="8,6"/>
                                    <Button Content="Pin" Style="{StaticResource PreviewOverlayButton}" Click="Pin_Click" ToolTip="Pin in history"/>
                                    <Button Content="Delete" Style="{StaticResource PreviewOverlayButton}" Click="Delete_Click" ToolTip="Delete from history"/>
                                </WrapPanel>
                            </Border>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="DetailMeta" Grid.Row="2" TextWrapping="Wrap" Foreground="{DynamicResource TextMutedBrush}"
                               FontSize="11" Margin="0,8,0,0"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
