<UserControl x:Class="CopyPastePro.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BgDarkBrush}">
    <Grid Background="{DynamicResource BgDarkBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource BgPanelBrush}" CornerRadius="12" Padding="8"
                Margin="0,0,4,0" BorderThickness="0">
            <StackPanel>
                <TextBlock Text="Settings" FontWeight="Bold" FontSize="16" Margin="8,8,8,12"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <ListBox x:Name="CategoryList" BorderThickness="0" Background="Transparent"
                         SelectionChanged="CategoryList_SelectionChanged"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="{DynamicResource BgPanelBrush}" CornerRadius="12" Padding="0"
                Margin="4,0,0,0" BorderThickness="0">
            <Grid Background="{DynamicResource BgPanelBrush}">
                <ScrollViewer x:Name="SettingsScroll" VerticalScrollBarVisibility="Auto" Padding="20,16,20,72"
                              Background="Transparent" BorderThickness="0">
                    <StackPanel x:Name="SettingsContent" Background="Transparent"/>
                </ScrollViewer>
                <Border VerticalAlignment="Bottom" Background="{DynamicResource BgPanelBrush}" Padding="16,12"
                        BorderThickness="0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Reset section" Style="{StaticResource GhostButton}" Click="ResetSection_Click" Margin="0,0,8,0"/>
                        <Button Content="Save all" Style="{StaticResource PrimaryButton}" Click="Save_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
